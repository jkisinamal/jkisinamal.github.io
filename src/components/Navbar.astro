---
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="fixed top-0 w-full z-50 px-4 md:px-8 py-6">
  <div class="max-w-7xl mx-auto flex justify-between items-center bg-zinc-50/90 dark:bg-zinc-900/90 backdrop-blur-xl border border-zinc-200 dark:border-zinc-800 px-6 py-4 rounded-full relative">
    
    <a href="/" class="font-serif text-xl tracking-tighter z-50 text-zinc-900 dark:text-zinc-50">JKISINAMAL</a>
    
    <div class="flex items-center space-x-4 md:space-x-8">
      <div class="hidden md:flex space-x-8 text-xs uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
        <a href="/" class="hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors">Gallery</a>
        <a href="/purchase" class="hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors">Purchase</a>
        <a href="/blog" class="hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors">Journal</a>
        <a href="/contact" class="hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors">Contact</a>
      </div>
      
      <div class="hidden md:block w-[1px] h-4 bg-zinc-200 dark:bg-zinc-800"></div>
      
      <ThemeToggle />

      <button 
        id="menu-toggle" 
        class="md:hidden flex flex-col justify-center items-center w-8 h-8 focus:outline-none z-50" 
        aria-label="Toggle Menu"
        style="--line-color: #18181b;" 
      >
        <div class="flex flex-col items-center justify-center space-y-1.5">
          <span class="nav-line w-5 h-0.5 transition-all duration-300 ease-in-out origin-center"></span>
          <span class="nav-line w-5 h-0.5 transition-all duration-300 ease-in-out origin-center"></span>
          <span class="nav-line w-5 h-0.5 transition-all duration-300 ease-in-out origin-center"></span>
        </div>
      </button>
    </div>

    <div 
      id="mobile-menu" 
      class="absolute top-[75px] left-0 w-full bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-3xl p-8 flex flex-col space-y-6 text-center shadow-2xl transition-all duration-300 ease-in-out opacity-0 translate-y-[-20px] pointer-events-none z-40"
    >
      <a href="/" class="text-xs uppercase tracking-[0.2em] text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-50 py-1">Gallery</a>
      <a href="/purchase" class="text-xs uppercase tracking-[0.2em] text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-50 py-1">Purchase</a>
      <a href="/blog" class="text-xs uppercase tracking-[0.2em] text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-50 py-1">Journal</a>
      <a href="/contact" class="text-xs uppercase tracking-[0.2em] text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-50 py-1">Contact</a>
    </div>
  </div>
</nav>

<style>
  /* Base color for light mode */
  .nav-line {
    background-color: var(--line-color);
  }

  /* Force white color in dark mode - Using !important to fight Brave */
  :global(.dark) #menu-toggle {
    --line-color: #fafafa !important;
  }

  /* Hamburger to X Animation */
  #menu-toggle.is-active span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #menu-toggle.is-active span:nth-child(2) {
    opacity: 0;
  }
  #menu-toggle.is-active span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Dropdown Toggle */
  #mobile-menu.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
</style>

<script is:inline>
  function setupMenu() {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    const newBtn = btn.cloneNode(true);
    btn.replaceWith(newBtn);

    newBtn.addEventListener('click', () => {
      newBtn.classList.toggle('is-active');
      menu.classList.toggle('is-visible');
    });

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        newBtn.classList.remove('is-active');
        menu.classList.remove('is-visible');
      });
    });
  }
  setupMenu();
  document.addEventListener('astro:after-swap', setupMenu);
</script>