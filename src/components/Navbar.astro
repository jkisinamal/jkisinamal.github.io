---
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="fixed top-0 w-full z-50 px-4 md:px-8 py-6">
  <div class="max-w-7xl mx-auto flex justify-between items-center bg-black/5 dark:bg-white/5 backdrop-blur-xl border border-black/10 dark:border-white/10 px-6 py-4 rounded-full relative">
    
    <a href="/" class="font-serif text-xl tracking-tighter z-50">JKISINAMAL</a>
    
    <div class="flex items-center space-x-4 md:space-x-8">
      <div class="hidden md:flex space-x-8 text-xs uppercase tracking-widest opacity-70">
        <a href="/" class="hover:opacity-100 transition">Gallery</a>
        <a href="/purchase" class="hover:opacity-100 transition">Purchase</a>
        <a href="/blog" class="hover:opacity-100 transition">Journal</a>
        <a href="/contact" class="hover:opacity-100 transition">Contact</a>
      </div>
      
      <div class="hidden md:block w-[1px] h-4 bg-black/10 dark:bg-white/10"></div>
      
      <ThemeToggle />

      <button 
        id="menu-toggle" 
        class="md:hidden flex flex-col justify-center items-center w-8 h-8 focus:outline-none z-50" 
        aria-label="Toggle Menu"
      >
        <div class="flex flex-col items-center justify-center space-y-1.5 w-full">
          <span class="w-5 h-0.5 bg-black dark:bg-white transition-all duration-300 ease-in-out origin-center"></span>
          <span class="w-5 h-0.5 bg-black dark:bg-white transition-all duration-300 ease-in-out origin-center"></span>
          <span class="w-5 h-0.5 bg-black dark:bg-white transition-all duration-300 ease-in-out origin-center"></span>
        </div>
      </button>
    </div>

    <div 
      id="mobile-menu" 
      class="absolute top-[75px] left-0 w-full bg-white/95 dark:bg-zinc-900/95 backdrop-blur-2xl border border-black/10 dark:border-white/10 rounded-3xl p-8 flex flex-col space-y-6 text-center shadow-2xl transition-all duration-300 ease-in-out opacity-0 translate-y-[-20px] pointer-events-none"
    >
      <a href="/" class="text-xs uppercase tracking-[0.2em] opacity-70 hover:opacity-100 py-1">Gallery</a>
      <a href="/purchase" class="text-xs uppercase tracking-[0.2em] opacity-70 hover:opacity-100 py-1">Purchase</a>
      <a href="/blog" class="text-xs uppercase tracking-[0.2em] opacity-70 hover:opacity-100 py-1">Journal</a>
      <a href="/contact" class="text-xs uppercase tracking-[0.2em] opacity-70 hover:opacity-100 py-1">Contact</a>
    </div>
  </div>
</nav>

<style>
  /* Menu Button State - Perfect X */
  #menu-toggle.is-active span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  
  #menu-toggle.is-active span:nth-child(2) {
    opacity: 0;
  }
  
  #menu-toggle.is-active span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Dropdown Visible State */
  #mobile-menu.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
</style>

<script is:inline>
  function setupMenu() {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');

    if (!btn || !menu) return;

    const newBtn = btn.cloneNode(true);
    btn.replaceWith(newBtn);

    newBtn.addEventListener('click', () => {
      newBtn.classList.toggle('is-active');
      menu.classList.toggle('is-visible');
    });

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        newBtn.classList.remove('is-active');
        menu.classList.remove('is-visible');
      });
    });
  }

  setupMenu();
  document.addEventListener('astro:after-swap', setupMenu);
</script>