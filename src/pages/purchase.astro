---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/sanity.ts';
import type { Artwork } from '../lib/types.ts';

const works: Artwork[] = await client.fetch(`*[_type == "artwork" && isAvailable == true]{
  title, 
  price, 
  medium,
  description,
  "imageUrl": image.asset->url, 
  "slug": slug.current
}`);

const formatPrice = (price: number) => {
  return new Intl.NumberFormat('en-PH', {
    style: 'currency',
    currency: 'PHP',
    maximumFractionDigits: 0,
  }).format(price);
};
---

<Layout title="Purchase | JKISINAMAL">
  <main class="pb-20 px-4 md:px-8 max-w-7xl mx-auto min-h-screen">
    <div class="mb-12 pt-6 md:pt-10 md:mb-16">
      <h1 class="font-serif text-5xl md:text-8xl italic mb-2 text-black dark:text-white">Available Works</h1>
      <p class="text-[9px] uppercase tracking-[0.3em] opacity-40">Direct acquisition from the studio</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-y-10 md:gap-x-12 md:gap-y-16">
      {works.map((w: Artwork) => (
        <div class="group relative flex flex-col p-4 rounded-[2rem] border border-black/5 dark:border-white/10 overflow-hidden glass-container shadow-sm">
          
          <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-white/10 dark:bg-black/10 backdrop-blur-md"></div>
          </div>

          <div class="relative z-10 flex flex-col h-full">
            <div class="relative overflow-hidden rounded-[1.5rem] mb-6 bg-zinc-100 dark:bg-zinc-900 border border-black/5 dark:border-white/5">
              <img src={w.imageUrl} alt={w.title} class="purchase-img w-full h-auto object-cover transition-all duration-700 ease-in-out" />
              
              <div class="purchase-details absolute inset-0 z-20 flex flex-col justify-end p-4 transition-opacity duration-500">
                <div class="glass-detail-card relative w-full p-5 rounded-2xl border border-white/40 dark:border-white/10 shadow-2xl overflow-hidden">
                  <div class="absolute inset-0 z-0">
                    <img src={w.imageUrl} class="absolute w-[400%] h-[400%] max-w-none blur-2xl opacity-60 grayscale" />
                    <div class="absolute inset-0 bg-white/70 dark:bg-black/80"></div>
                  </div>
                  <div class="relative z-10 text-left">
                    <span class="text-[8px] uppercase tracking-widest text-black/40 dark:text-white/40 mb-1 block">{w.medium}</span>
                    <h2 class="text-xl mb-1 text-zinc-900 dark:text-white font-serif italic leading-none">{w.title}</h2>
                    <p class="text-zinc-700 dark:text-zinc-300 text-xs italic line-clamp-2">{w.description}</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-5 px-1 pb-1">
              <div>
                <h3 class="text-2xl font-serif text-black dark:text-white italic leading-tight">{w.title}</h3>
                <p class="text-lg font-light text-black/60 dark:text-white/40">
                  {w.price ? formatPrice(w.price) : 'Contact for Price'}
                </p>
              </div>

              <a 
                href={`/contact?interest=${encodeURIComponent(w.title)}`} 
                class="w-full sm:w-auto text-center bg-black text-white dark:bg-white dark:text-black px-10 py-4 rounded-full font-bold text-[9px] uppercase tracking-widest transition-all hover:scale-105 active:scale-95"
              >
                Inquire
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  @reference "../styles/global.css";
  
  /* DEFAULT: Detail card hidden on small screens unless we want it visible */
  .purchase-details { opacity: 0; pointer-events: none; }

  /* HOVER LOGIC for Mouse Users */
  @media (hover: hover) {
    .group:hover .purchase-details { opacity: 1; }
    .group:hover .purchase-img { transform: scale(1.05); }
  }

  .glass-container, .glass-detail-card { 
    contain: paint; 
    isolation: isolate; 
    -webkit-mask-image: -webkit-radial-gradient(white, black);
  }
  .glass-detail-card { 
    background: transparent; 
    -webkit-backdrop-filter: blur(10px); 
    backdrop-filter: blur(10px); 
  }
</style>