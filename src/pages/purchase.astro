---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/sanity';
import type { Painting } from '../lib/types';

const works: Painting[] = await client.fetch(`*[_type == "painting" && category == "available"]{
  title, price, "imageUrl": image.asset->url, "slug": slug.current
}`);
---
<Layout title="Acquire Art | Available Collection">
  <main class="pt-32 px-4 md:px-8 max-w-7xl mx-auto min-h-screen">
    <h1 class="font-serif text-5xl md:text-7xl mb-16 italic font-light text-black dark:text-white">Available Works</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      {works.map((w: Painting) => (
        <div class="group bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-3xl p-6 transition-all hover:bg-black/[0.08] dark:hover:bg-white/[0.08]">
          <div class="overflow-hidden rounded-2xl mb-8">
             <img src={w.imageUrl} alt={w.title} class="w-full aspect-square object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>
          <div class="flex justify-between items-center">
            <div>
              <h3 class="text-3xl font-serif text-black dark:text-white">{w.title}</h3>
              <p class="text-black/40 dark:text-white/40 mt-1">${w.price?.toLocaleString()} USD</p>
            </div>
            <a 
              href={`/contact?interest=${w.slug}`} 
              class="bg-black text-white dark:bg-white dark:text-black px-8 py-4 rounded-full font-bold hover:scale-105 transition-all shadow-xl shadow-black/5 dark:shadow-white/5"
            >
              Inquire
            </a>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>