---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | JKISINAMAL">
  <main class="pt-8 md:pt-14 pb-20 px-6 md:px-8 max-w-5xl mx-auto min-h-screen">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">
      
      <div class="relative group order-first">
        <div class="absolute -inset-2 bg-zinc-50 dark:bg-zinc-900 rounded-[2.5rem] -z-10"></div>
        <img 
          src="/artist-portrait.jpg" 
          alt="JKISINAMAL" 
          class="rounded-[2rem] w-full aspect-[4/5] md:aspect-[3/4] object-cover grayscale shadow-2xl transition-all duration-700 group-hover:grayscale-0"
        />
      </div>
      
      <div class="space-y-6 md:space-y-8 flex flex-col justify-center">
        <div>
          <h1 class="font-serif text-5xl md:text-7xl italic leading-tight mb-4 text-black dark:text-white">
            JKISINAMAL
          </h1>
          <div class="w-12 h-[1px] bg-black/20 dark:white/20 mb-6"></div>
        </div>

        <div class="prose dark:prose-invert prose-neutral max-w-none">
          <p class="text-lg md:text-xl font-light text-zinc-700 dark:text-zinc-300 leading-relaxed">
            A visual artist exploring the boundaries between classical medium and digital interpretation.
          </p>
          <p class="text-zinc-500 dark:text-zinc-500 leading-relaxed text-sm md:text-base">
            Based in the Philippines, the work of JKISINAMAL is defined by a meticulous approach to light, texture, and the raw expression of form. Each stroke in oil or acrylic serves as a bridge between internal emotion and external reality.
          </p>
        </div>
        
        <div class="pt-8 md:pt-12 border-t border-black/10 dark:border-white/10">
          <p class="text-[9px] md:text-[10px] uppercase tracking-[0.4em] opacity-40 mb-6 font-bold">Exhibitions</p>
          <ul class="space-y-4 text-xs md:text-sm">
            <li class="flex justify-between items-end border-b border-black/5 dark:border-white/5 pb-2">
              <span class="font-medium">Contemporary Manila</span> 
              <span class="opacity-40 italic">2026</span>
            </li>
            <li class="flex justify-between items-end border-b border-black/5 dark:border-white/5 pb-2">
              <span class="font-medium">Digital Dialogue Exhibit</span> 
              <span class="opacity-40 italic">2025</span>
            </li>
          </ul>
        </div>

        <div class="pt-6">
          <a 
            href="/contact" 
            class="inline-block w-full md:w-auto text-center border border-black/10 dark:border-white/10 px-8 py-4 rounded-full text-[10px] uppercase tracking-widest hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all duration-300"
          >
            Get in touch
          </a>
        </div>
      </div>

    </div>
  </main>
</Layout>

<style>
  /* Entrance animation for mobile fluidity */
  main {
    animation: fadeIn 0.8s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Prevent awkward text wrapping on very small screens */
  @media (max-width: 380px) {
    h1 { font-size: 2.5rem; }
  }
</style>