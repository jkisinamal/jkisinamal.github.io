---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/sanity.ts';
import { PortableText } from '@portabletext/react';

export async function getStaticPaths() {
  const posts = await client.fetch(`*[_type == "post"]{ "params": { "slug": slug.current } }`);
  return posts;
}

const { slug } = Astro.params;
const post = await client.fetch(`*[_type == "post" && slug.current == $slug][0]{
  title,
  body,
  publishedAt,
  videoSource,
  videoUrl,
  "uploadedVideoUrl": videoFile.asset->url,
  "mainImageUrl": mainImage.asset->url
}`, { slug });

// Helper to format YouTube and Google Drive links for embedding
function formatVideoUrl(url: string) {
  if (!url) return null;
  
  // YouTube transform
  if (url.includes('youtube.com/watch?v=')) {
    return url.replace('watch?v=', 'embed/');
  }
  if (url.includes('youtu.be/')) {
    return url.replace('youtu.be/', 'youtube.com/embed/');
  }

  // Google Drive transform (Converts 'view' link to 'preview' for iframe)
  if (url.includes('drive.google.com')) {
    return url.replace('/view', '/preview');
  }

  return url;
}

const finalVideoUrl = post.videoSource === 'upload' ? post.uploadedVideoUrl : formatVideoUrl(post.videoUrl);
const isExternal = post.videoSource === 'link';
---

<Layout title={`${post.title} | Journal`}>
  <article class="pb-20 px-4 md:px-8 max-w-6xl mx-auto">
    
    <div class="w-full overflow-hidden rounded-[2.5rem] mb-20 bg-zinc-100 dark:bg-zinc-900">
      {finalVideoUrl ? (
        <div class="aspect-video w-full">
          {/* Use Iframe for YouTube/Drive, Video tag for direct uploads */}
          {isExternal ? (
            <iframe 
              src={finalVideoUrl} 
              class="w-full h-full" 
              allow="autoplay; fullscreen" 
              allowfullscreen
            ></iframe>
          ) : (
            <video 
              src={finalVideoUrl} 
              controls 
              class="w-full h-full object-cover"
            />
          )}
        </div>
      ) : post.mainImageUrl && (
        <img src={post.mainImageUrl} class="w-full h-auto object-contain" />
      )}
    </div>

    <div class="max-w-4xl mx-auto">
      <header class="mb-16">
        <time class="text-[10px] uppercase tracking-[0.3em] text-zinc-400 mb-4 block">
          {new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="font-serif text-6xl md:text-8xl text-zinc-900 dark:text-white leading-tight">
          {post.title}
        </h1>
      </header>

      <div class="blog-content prose prose-neutral dark:prose-invert max-w-none">
        <PortableText value={post.body} />
      </div>
    </div>
  </article>
</Layout>