---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/sanity.ts';
import type { Post } from '../../lib/types.ts';

const posts: Post[] = await client.fetch(`*[_type == "post"] | order(publishedAt desc){
  title, 
  slug, 
  publishedAt, 
  excerpt,
  "mainImageUrl": mainImage.asset->url
}`);
---

<Layout title="Journal | JKISINAMAL">
  <main class="pb-20 px-4 md:px-8 max-w-6xl mx-auto min-h-screen">
    
    <header class="pb-12 border-b border-black/5 dark:border-white/5 mb-16">
      <h1 class="font-serif text-6xl md:text-8xl italic text-zinc-900 dark:text-white tracking-tight">
        Journal
      </h1>
      <p class="mt-4 text-[10px] uppercase tracking-[0.3em] opacity-40">
        Observations, Process, & Works in Progress
      </p>
    </header>

    <div class="space-y-24">
      {posts.map((post: Post, index: number) => (
        <a href={`/blog/${post.slug.current}`} class="group block relative">
          <div class={`flex flex-col ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-8 md:gap-16 items-center`}>
            
            <div class="w-full md:w-1/2 overflow-hidden rounded-2xl aspect-video md:aspect-[4/3] bg-zinc-100 dark:bg-zinc-900 border border-black/5 dark:border-white/5">
              {post.mainImageUrl && (
                <img 
                  src={post.mainImageUrl} 
                  alt={post.title} 
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105"
                />
              )}
            </div>

            <div class="w-full md:w-1/2 space-y-4">
              <time class="text-[9px] uppercase tracking-[0.3em] text-zinc-400 block">
                {new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
              
              <h2 class="text-3xl md:text-5xl font-serif text-zinc-900 dark:text-white leading-tight group-hover:italic transition-all duration-500">
                {post.title}
              </h2>
              
              <p class="text-zinc-500 dark:text-zinc-400 text-base font-light leading-relaxed line-clamp-3">
                {post.excerpt}
              </p>

              <div class="pt-4 flex items-center space-x-4">
                <span class="w-8 h-[1px] bg-black dark:bg-white origin-left transition-transform duration-500 group-hover:scale-x-150"></span>
                <span class="text-[9px] uppercase tracking-widest font-bold">Read Entry</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  @reference "../../styles/global.css";
</style>