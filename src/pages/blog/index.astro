---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/sanity';
import type { Post } from '../../lib/types';

const posts: Post[] = await client.fetch(`*[_type == "post"] | order(publishedAt desc){
  title, slug, publishedAt, excerpt
}`);
---
<Layout title="Journal | Artist's Process">
  <main class="pt-40 px-6 max-w-4xl mx-auto min-h-screen">
    <h1 class="font-serif text-7xl md:text-9xl mb-24 italic text-center opacity-80">Journal</h1>
    <div class="space-y-32">
      {posts.map((post: Post) => (
        <a href={`/blog/${post.slug.current}`} class="group block border-b border-white/5 pb-20 last:border-0">
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between">
            <span class="text-xs uppercase tracking-[0.3em] text-white/30 mb-4 md:mb-0">
              {new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </span>
          </div>
          <h2 class="text-4xl md:text-6xl font-serif mt-6 group-hover:italic transition-all duration-500 group-hover:translate-x-4">
            {post.title}
          </h2>
          <p class="mt-8 text-white/50 text-lg max-w-2xl leading-relaxed font-light line-clamp-2">
            {post.excerpt}
          </p>
          <div class="mt-10 flex items-center space-x-4 text-xs uppercase tracking-widest font-bold">
            <span class="w-10 h-[1px] bg-white/20"></span>
            <span>Read Entry</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>