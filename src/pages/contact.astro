---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | JKISINAMAL">
  <main class="pt-14 pb-20 px-4 md:px-8 max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <div class="relative group">
        <div class="absolute -inset-4 bg-zinc-100 dark:bg-zinc-800 rounded-3xl -z-10 transition-transform duration-700 group-hover:scale-105"></div>
        <img 
          src="/artist-studio.jpg" 
          alt="The Studio" 
          class="rounded-2xl shadow-2xl w-full aspect-[4/5] object-cover grayscale hover:grayscale-0 transition-all duration-1000"
        />
      </div>

      <div class="max-w-md">
        <h1 class="font-serif text-6xl italic mb-6">Get in Touch</h1>
        <p class="text-zinc-500 dark:text-zinc-400 mb-12 leading-relaxed">
          For inquiries regarding available works, commissions, or collaborations, please use the form below.
        </p>

        <form action="#" class="space-y-6">
          <div class="space-y-2">
            <label class="text-[10px] uppercase tracking-widest opacity-50">Full Name</label>
            <input type="text" class="w-full bg-transparent border-b border-black/10 dark:border-white/10 py-3 focus:border-black dark:focus:border-white outline-none transition-colors" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] uppercase tracking-widest opacity-50">Email Address</label>
            <input type="email" class="w-full bg-transparent border-b border-black/10 dark:border-white/10 py-3 focus:border-black dark:focus:border-white outline-none transition-colors" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] uppercase tracking-widest opacity-50">Message</label>
            <textarea rows="4" class="w-full bg-transparent border-b border-black/10 dark:border-white/10 py-3 focus:border-black dark:focus:border-white outline-none transition-colors resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-black text-white dark:bg-white dark:text-black py-5 rounded-full text-xs uppercase tracking-[0.2em] font-bold hover:opacity-80 transition-opacity">
            Send Inquiry
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>