---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/sanity.ts';
import type { Artwork } from '../lib/types.ts';

const artworks: Artwork[] = await client.fetch(`*[_type == "artwork" && showInGallery == true]{
  title, 
  "imageUrl": image.asset->url, 
  description, 
  medium
}`);

const filters = [
  { label: 'All', value: 'all' },
  { label: 'Oil', value: 'oil' },
  { label: 'Acrylic', value: 'acrylic' },
  { label: 'Sketches', value: 'sketch' }
];
---

<Layout title="Gallery | JKISINAMAL">
  <main class="pb-20 px-4 md:px-8">
    <div class="max-w-7xl mx-auto text-center">
      <div class="flex flex-wrap justify-center gap-3 mb-16">
        {filters.map(f => (
          <button 
            data-filter={f.value}
            class="filter-btn px-8 py-3 rounded-full border border-black/5 dark:border-white/10 text-[10px] uppercase tracking-[0.2em] transition-all duration-300 hover:scale-105 bg-zinc-50 dark:bg-zinc-900 text-zinc-500 hover:text-black dark:hover:text-white"
          >
            {f.label}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="gallery-grid">
        {artworks.map((p: Artwork) => (
          <div class="painting-card group relative aspect-[3/4] overflow-hidden rounded-2xl border border-black/5 dark:border-white/10 bg-zinc-100 dark:bg-zinc-800 cursor-pointer" data-medium={p.medium}>
            <img src={p.imageUrl} alt={p.title} class="painting-img w-full h-full object-cover transition-all duration-700 grayscale-0 group-hover:grayscale group-hover:scale-105" />
            <div class="absolute inset-0 z-20 flex flex-col justify-end p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
              <div class="glass-card relative w-full p-6 rounded-2xl border border-white/40 dark:border-white/10 shadow-2xl overflow-hidden">
                <div class="absolute inset-0 z-0">
                  <img src={p.imageUrl} class="absolute w-[400%] h-[400%] max-w-none blur-2xl opacity-60 grayscale" />
                  <div class="absolute inset-0 bg-white/70 dark:bg-black/70"></div>
                </div>
                <div class="relative z-10 text-left">
                  <span class="text-[9px] uppercase tracking-widest text-black/40 dark:text-white/40 mb-1 block">{p.medium}</span>
                  <h2 class="text-2xl mb-1 text-zinc-900 dark:text-white font-serif italic">{p.title}</h2>
                  <p class="text-zinc-700 dark:text-zinc-300 text-sm italic line-clamp-2">{p.description}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  @reference "../styles/global.css";
  .painting-card { contain: paint; isolation: isolate; }
  .filter-btn.is-active { @apply border-black dark:border-white text-black dark:text-white bg-white dark:bg-zinc-800 shadow-lg scale-105; }
  .glass-card { background: transparent; -webkit-backdrop-filter: blur(8px); }
</style>

<script>
  function setupGallery() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.painting-card');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        const filter = btn.getAttribute('data-filter');
        cards.forEach(card => {
          const m = card.getAttribute('data-medium');
          (card as HTMLElement).style.display = (filter === 'all' || m === filter) ? 'block' : 'none';
        });
      });
    });
    const allBtn = document.querySelector('[data-filter="all"]');
    if (allBtn) allBtn.classList.add('is-active');
  }
  setupGallery();
  document.addEventListener('astro:after-swap', setupGallery);
</script>