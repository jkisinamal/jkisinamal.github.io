---
import { sanityClient } from "sanity:client";

// 1. Define the shape of your project data
interface Project {
  title: string;
  description: string;
  imageUrl: string;
}

// 2. Tell the fetch command to expect an array of Projects
const projects = await sanityClient.fetch<Project[]>(`*[_type == "project"]{
  title,
  description,
  "imageUrl": image.asset->url
}`);
---

<html lang="en">
  <body>
    <h1>Portfolio Projects</h1>
    
    <div class="projects-grid">
      {projects.map((project) => ( // TypeScript now knows 'project' is a 'Project'
        <div class="project-card">
          {project.imageUrl && (
            <img src={project.imageUrl} alt={project.title} width="300" />
          )}
          <h2>{project.title}</h2>
          <p>{project.description}</p>
        </div>
      ))}
    </div>
  </body>
</html>