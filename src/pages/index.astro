---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/sanity';
import type { Painting } from '../lib/types';

const paintings: Painting[] = await client.fetch(`*[_type == "painting" && category == "gallery"]{
  title, "imageUrl": image.asset->url, description
}`);
---
<Layout title="Gallery | Fine Art Portfolio">
  <main class="pt-32 pb-20 px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {paintings.map((p: Painting) => (
        <div 
          class="painting-card group relative aspect-3/4 overflow-hidden rounded-xl border border-black/5 dark:border-white/10 bg-white/5 cursor-pointer"
          tabindex="0"
        >
          <img 
            src={p.imageUrl} 
            alt={p.title}
            class="w-full h-full object-cover transition-all duration-1000 grayscale-0 group-[.is-active]:grayscale group-hover:grayscale group-[.is-active]:scale-110 group-hover:scale-110" 
          />
          
          <div class="absolute inset-0 flex flex-col justify-end p-6 opacity-0 group-[.is-active]:opacity-100 group-hover:opacity-100 transition-all duration-500">
            
            <div class="glass-card w-full p-6 rounded-2xl border border-white/20 dark:border-white/10 backdrop-blur-md shadow-2xl translate-y-8 group-[.is-active]:translate-y-0 group-hover:translate-y-0 transition-transform duration-500">
              <h2 class="font-serif text-2xl mb-2 text-zinc-900 dark:text-white">
                {p.title}
              </h2>
              <p class="text-zinc-700 dark:text-zinc-300 text-sm italic font-light leading-relaxed">
                {p.description}
              </p>
            </div>

          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  /* Glassmorphism Styles */
  .glass-card {
    /* Adaptive background for light/dark themes */
    background: rgba(255, 255, 255, 0.7);
  }

  :global(.dark) .glass-card {
    background: rgba(15, 15, 15, 0.6);
  }
</style>

<script>
  function setupGallery() {
    const cards = document.querySelectorAll('.painting-card');
    
    cards.forEach(card => {
      // Toggle active state on click (Mobile)
      card.addEventListener('click', (e) => {
        if (card.classList.contains('is-active')) {
          card.classList.remove('is-active');
        } else {
          cards.forEach(c => c.classList.remove('is-active'));
          card.classList.add('is-active');
        }
      });
    });

    // Reset when clicking outside
    document.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('.painting-card')) {
        cards.forEach(c => c.classList.remove('is-active'));
      }
    });
  }

  setupGallery();
  document.addEventListener('astro:after-swap', setupGallery);
</script>